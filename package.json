    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.24",
    "@ai-sdk/openai": "^3.0.30",
    "ai": "^6.0.97"
  }
}
